# Заполняется install.sh. Никогда не коммитить реальный .env.

# Telegram bot token от @BotFather
BOT_TOKEN=__BOT_TOKEN__

# Telegram user_id администраторов через запятую (минимум один — владелец салона)
ADMIN_IDS=__ADMIN_IDS__

# Идентификатор салона-арендатора: [a-z0-9-], например 'nails-chilanzar'.
# Используется в именах контейнеров, томов, caption бэкапов, тегах логов.
TENANT_SLUG=__TENANT_SLUG__

# Часовой пояс (IANA), по умолчанию Ташкент
TIMEZONE=Asia/Tashkent

# Telegram chat_id приватного канала для облачной копии БД. Пусто — локальный бэкап есть,
# облачного нет. Рекомендуется: канал, где владелец = автор бота, бот в админах с правом
# публикации. Пример: -1001234567890
BACKUP_CHAT_ID=__BACKUP_CHAT_ID__

# Telegram chat_id приватного канала для алертов об unhandled exceptions.
# Пусто — ошибки только в stderr. Можно тот же канал что BACKUP_CHAT_ID — разные caption.
ERROR_CHAT_ID=__ERROR_CHAT_ID__

# Лицензионный ключ (выдаётся автором через tools/issue_license.py). Пусто и
# публичный ключ проставлен → бот уходит в restricted mode (только /start).
LICENSE_KEY=__LICENSE_KEY__

# URL heartbeat-эндпоинта автора. Пусто → heartbeat не шлётся. Провал запроса
# никогда не блокирует бот.
HEARTBEAT_URL=__HEARTBEAT_URL__

# Контакт для сообщения об истёкшей лицензии. Например: @sabina_nails_author
LICENSE_CONTACT=__LICENSE_CONTACT__

# ─── Платежи (Phase 1 v.4) ────────────────────────────────────────────
# click | payme | none. "none" — кнопки нет либо legacy PAYMENT_URL-deeplink.
PAYMENT_PROVIDER=none

# Legacy (если PAYMENT_PROVIDER=none и хочется кнопку-ссылку):
# PAYMENT_URL=https://my.click.uz/services/pay?service_id=XXX&merchant_id=YYY&amount={amount}&transaction_param={appt_id}
# PAYMENT_LABEL=Оплатить

# Click Merchant API (https://merchant.click.uz)
CLICK_SERVICE_ID=
CLICK_MERCHANT_ID=
CLICK_MERCHANT_USER_ID=
CLICK_SECRET_KEY=

# Payme Merchant API (https://merchant.paycom.uz)
PAYME_MERCHANT_ID=
PAYME_SECRET_KEY=

# Публичный HTTPS-URL, куда Caddy/nginx проксирует webhook'и провайдеров.
# Пример: https://bot.sabinanails.uz (без слеша в конце).
PAYMENT_PUBLIC_URL=
# Порт локального aiohttp (за reverse-proxy). Прокидывается в docker-compose.yml.
PAYMENT_WEBHOOK_PORT=8443

# ── Dev / локальный тест через mock (tools/mock_click_server.py) ──
# Запускается отдельным процессом: python tools/mock_click_server.py
# Тогда в этом .env ставим:
#   CLICK_API_BASE=http://localhost:8444/mock-click/v2/merchant
#   CLICK_PAY_URL_BASE=http://localhost:8444/mock-click/pay
#   PAYMENT_PUBLIC_URL=http://localhost:8443
# В проде оставить пустыми — fallback на прод Click.
CLICK_API_BASE=
CLICK_PAY_URL_BASE=
