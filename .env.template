# Заполняется install.sh. Никогда не коммитить реальный .env.

# Telegram bot token от @BotFather
BOT_TOKEN=__BOT_TOKEN__

# Telegram user_id администраторов через запятую (минимум один — владелец салона)
ADMIN_IDS=__ADMIN_IDS__

# Идентификатор салона-арендатора: [a-z0-9-], например 'nails-chilanzar'.
# Используется в именах контейнеров, томов, caption бэкапов, тегах логов.
TENANT_SLUG=__TENANT_SLUG__

# Часовой пояс (IANA), по умолчанию Ташкент
TIMEZONE=Asia/Tashkent

# Telegram chat_id приватного канала для облачной копии БД. Пусто — локальный бэкап есть,
# облачного нет. Рекомендуется: канал, где владелец = автор бота, бот в админах с правом
# публикации. Пример: -1001234567890
BACKUP_CHAT_ID=__BACKUP_CHAT_ID__

# Telegram chat_id приватного канала для алертов об unhandled exceptions.
# Пусто — ошибки только в stderr. Можно тот же канал что BACKUP_CHAT_ID — разные caption.
ERROR_CHAT_ID=__ERROR_CHAT_ID__

# Ключ лицензии. Phase 5 добавит верификацию; сейчас — placeholder, бот не проверяет.
LICENSE_KEY=
